<Window x:Class="MinecraftLauncher.AIConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MinecraftLauncher.Helpers"
        Title="AI 设置" Height="620" Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">
    <Border Background="{DynamicResource PrimaryBackgroundBrush}" 
            CornerRadius="12" BorderBrush="{DynamicResource TertiaryBackgroundBrush}" 
            BorderThickness="2">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🤖 AI 助手配置" FontSize="20" FontWeight="Bold" 
                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,15"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="🔑 API Key" Foreground="{DynamicResource SecondaryForegroundBrush}" 
                               FontSize="13" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="ApiKeyBox" Height="36" Margin="0,0,0,12"
                                Background="{DynamicResource TertiaryBackgroundBrush}"
                                Foreground="{DynamicResource PrimaryForegroundBrush}"
                                BorderThickness="0" Padding="10,0"/>

                    <TextBlock Text="🌐 API Endpoint（可选，默认使用 OpenAI）" 
                               Foreground="{DynamicResource SecondaryForegroundBrush}" 
                               FontSize="13" Margin="0,0,0,4"
                               TextWrapping="Wrap"/>
                    <TextBox x:Name="ApiEndpointBox" Height="36" Margin="0,0,0,12"
                             Text="https://api.openai.com/v1"
                             Style="{DynamicResource ModernTextBox}"/>

                    <TextBlock Text="🧠 模型选择" 
                               Foreground="{DynamicResource SecondaryForegroundBrush}" 
                               FontSize="13" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ModelComboBox" Height="36" Margin="0,0,0,12"
                              SelectedIndex="0">
                        <ComboBoxItem Content="gpt-4o-mini (推荐，性价比高)"/>
                        <ComboBoxItem Content="gpt-4o (更强能力)"/>
                        <ComboBoxItem Content="gpt-3.5-turbo (快速响应)"/>
                    </ComboBox>

                    <TextBlock Text="💬 最大历史消息数" 
                               Foreground="{DynamicResource SecondaryForegroundBrush}" 
                               FontSize="13" Margin="0,0,0,4"/>
                    <Slider x:Name="HistorySlider" Minimum="5" Maximum="50" Value="20" 
                            TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,0,0,4"/>
                    <TextBlock x:Name="HistoryValueText" Text="20" 
                               Foreground="{DynamicResource AccentBrush}" FontSize="13"
                               Margin="0,0,0,12"/>

                    <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                            CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="⚙️ 功能设置" FontWeight="Bold" 
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8"/>
                            
                            <CheckBox x:Name="SendHardwareInfoCheckBox" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="发送硬件信息给 AI" 
                                               Foreground="{DynamicResource PrimaryForegroundBrush}" 
                                               VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </CheckBox>
                            
                            <CheckBox x:Name="EnableAutoDiagnosisCheckBox" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="自动诊断游戏错误" 
                                               Foreground="{DynamicResource PrimaryForegroundBrush}" 
                                               VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </CheckBox>
                            
                            <CheckBox x:Name="EnableProactiveSuggestionsCheckBox">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="主动提供优化建议" 
                                               Foreground="{DynamicResource PrimaryForegroundBrush}" 
                                               VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                            CornerRadius="8" Padding="12">
                        <StackPanel>
                            <TextBlock Text="💡 提示" FontWeight="Bold" 
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{DynamicResource SecondaryForeground}">
                                您可以使用 OpenAI API、其他兼容的 API（如 Azure OpenAI、Claude 等）。API Key 仅保存在本地配置文件中，不会发送给任何人。
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="取消" Click="CancelButton_Click"
                        Style="{StaticResource ModernButton}"
                        Width="80" Margin="0,0,10,0"
                        helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
                <Button Content="保存" Click="SaveButton_Click"
                        Style="{StaticResource ModernButton}"
                        Width="80"
                        helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Page x:Class="MinecraftLauncher.AIAssistantPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:MinecraftLauncher.Helpers"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="{DynamicResource PrimaryBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="Brain" Width="28" Height="28" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="AI 助手" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="SettingsButton" Content="设置"
                        Click="SettingsButton_Click"
                        Style="{StaticResource ModernButton}"
                        Margin="0,0,10,0"
                        helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
                <Button x:Name="ClearButton" Content="清空对话"
                        Click="ClearButton_Click"
                        Style="{StaticResource ModernButton}"
                        helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource CardContainer}" Margin="0,0,0,15" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource TertiaryBackgroundBrush}"
                        CornerRadius="10" Padding="15" Margin="0,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <iconPacks:PackIconMaterial Kind="DesktopClassic" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="硬件信息" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="CpuInfoText" Text="CPU: 检测中..."
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock x:Name="MemoryInfoText" Text="内存: 检测中..."
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock x:Name="GpuInfoText" Text="GPU: 检测中..."
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource TertiaryBackgroundBrush}"
                        CornerRadius="10" Padding="15" Margin="8,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <iconPacks:PackIconMaterial Kind="Flash" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="快捷功能" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                        <WrapPanel>
                            <Button x:Name="OptimizeButton" Content="配置优化"
                                    Click="OptimizeButton_Click"
                                    Style="{StaticResource ModernButton}"
                                    Margin="0,0,6,6"
                                    Padding="10,6"
                                    FontSize="11"
                                    helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
                            <Button x:Name="DiagnoseButton" Content="问题诊断"
                                    Click="DiagnoseButton_Click"
                                    Style="{StaticResource ModernButton}"
                                    Margin="0,0,6,6"
                                    Padding="10,6"
                                    FontSize="11"
                                    helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
                            <Button x:Name="AnalyzeModsButton" Content="模组分析"
                                    Click="AnalyzeModsButton_Click"
                                    Style="{StaticResource ModernButton}"
                                    Margin="0,0,6,6"
                                    Padding="10,6"
                                    FontSize="11"
                                    helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
                            <Button x:Name="AnalyzeSavesButton" Content="存档分析"
                                    Click="AnalyzeSavesButton_Click"
                                    Style="{StaticResource ModernButton}"
                                    Margin="0,0,6,6"
                                    Padding="10,6"
                                    FontSize="11"
                                    helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
                            <Button x:Name="ViewLogsButton" Content="日志分析"
                                    Click="ViewLogsButton_Click"
                                    Style="{StaticResource ModernButton}"
                                    Margin="0,0,6,6"
                                    Padding="10,6"
                                    FontSize="11"
                                    helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource TertiaryBackgroundBrush}"
                        CornerRadius="10" Padding="15" Margin="8,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <iconPacks:PackIconMaterial Kind="GamepadVariant" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="游戏助手" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                        <WrapPanel>
                            <Button x:Name="RecipeButton" Content="合成配方"
                                    Click="RecipeButton_Click"
                                    Style="{StaticResource ModernButton}"
                                    Margin="0,0,6,6"
                                    Padding="10,6"
                                    FontSize="11"
                                    helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
                            <Button x:Name="ModsButton" Content="模组推荐"
                                    Click="ModsButton_Click"
                                    Style="{StaticResource ModernButton}"
                                    Margin="0,0,6,6"
                                    Padding="10,6"
                                    FontSize="11"
                                    helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
                        </WrapPanel>
                        <TextBlock x:Name="VersionCountText" Text="已安装版本: 0 个"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   FontSize="11" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource SecondaryBackgroundBrush}"
                CornerRadius="10" Margin="0,0,0,15">
            <Grid>
                <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Padding="18">
                    <StackPanel x:Name="ChatMessagesPanel">
                        <Border Background="{DynamicResource TertiaryBackgroundBrush}"
                                CornerRadius="10" Padding="16" Margin="0,0,0,12"
                                HorizontalAlignment="Left" MaxWidth="550">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <iconPacks:PackIconMaterial Kind="Robot" Width="16" Height="16" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="🤖 小矿工" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}" FontSize="13"/>
                                </StackPanel>
                                <TextBlock Text="你好！我是你的 Minecraft 启动器智能助手「小矿工」。我可以帮助你：&#x0a;&#x0a;• 📦 管理和诊断模组问题&#x0a;• 💾 分析存档状态&#x0a;• 🔧 优化游戏配置&#x0a;• 🐛 排查游戏崩溃问题&#x0a;• 📝 实时监控游戏日志&#x0a;&#x0a;请在下方输入你的问题！"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="14"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border x:Name="LoadingPanel" Visibility="Collapsed"
                        Background="#80000000" CornerRadius="10">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Loading" Width="32" Height="32" Foreground="White" Spin="True"/>
                        <TextBlock Text="思考中..." Foreground="White" FontSize="14" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputTextBox"
                     Style="{DynamicResource ModernTextBox}"
                     AcceptsReturn="False"
                     KeyDown="InputTextBox_KeyDown"
                     VerticalContentAlignment="Center"
                     FontSize="14"
                     Padding="12,10"/>
            <Button Grid.Column="1" x:Name="SendButton" Content="发送"
                    Click="SendButton_Click"
                    Style="{StaticResource ModernButton}"
                    Margin="12,0,0,0"
                    Padding="24,10"
                    FontSize="14"
                    helpers:AnimationBehaviors.EnableButtonAnimation="True"/>
        </Grid>
    </Grid>
</Page>

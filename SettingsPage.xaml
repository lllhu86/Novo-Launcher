<Page x:Class="MinecraftLauncher.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="设置" Background="Transparent">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <!-- 版本隔离卡片 -->
            <Border Style="{StaticResource CardContainer}">
                <StackPanel>
                    <TextBlock Text="版本隔离" FontSize="18" FontWeight="Bold" 
                             Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                    
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="13" Margin="0,0,0,15">
                        版本隔离用于区分不同版本的游戏文件（如 mods、存档等），避免版本冲突。<LineBreak/>
                        开启后，每个版本将拥有独立的配置文件和 mod 文件夹。
                    </TextBlock>
                    
                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="版本隔离模式" VerticalAlignment="Center" 
                                 Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <ComboBox Grid.Column="1" x:Name="IsolationComboBox" 
                                Style="{StaticResource ModernComboBox}" 
                                SelectedIndex="1" SelectionChanged="IsolationComboBox_SelectionChanged">
                            <ComboBoxItem Content="不开启"/>
                            <ComboBoxItem Content="隔离可安装 mod 的版本与非正式版"/>
                            <ComboBoxItem Content="隔离所有版本"/>
                            <ComboBoxItem Content="自定义"/>
                        </ComboBox>
                    </Grid>
                    
                    <Border x:Name="IsolationInfoBorder" Background="{DynamicResource TertiaryBackgroundBrush}" 
                          CornerRadius="8" Padding="15" Margin="0,15,0,0"
                          BorderBrush="{DynamicResource SecondaryBackgroundBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="IsolationInfoText" 
                                     TextWrapping="Wrap" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- 游戏内存卡片 -->
            <Border Style="{StaticResource CardContainer}" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock Text="游戏内存" FontSize="18" FontWeight="Bold" 
                             Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,15"/>
                    
                    <RadioButton x:Name="AutoMemoryRadio" Content="自动配置" 
                               Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="14" 
                               IsChecked="True" Margin="0,5"
                               Checked="AutoMemoryRadio_Checked"/>
                    
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="CustomMemoryRadio" Content="自定义" 
                                   Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="14" 
                                   Margin="0,0,15,0"
                                   Checked="CustomMemoryRadio_Checked"/>
                        <Slider Grid.Column="1" x:Name="MemorySlider" 
                              Minimum="512" Maximum="16384" Value="2048" 
                              IsEnabled="False" ValueChanged="MemorySlider_ValueChanged"
                              TickFrequency="256" IsSnapToTickEnabled="True"
                              Margin="0,5,0,0"/>
                        <TextBlock Grid.Column="2" x:Name="MemoryValueText" 
                                 Text="2048 MB" Foreground="{DynamicResource AccentBrush}" 
                                 FontSize="14" VerticalAlignment="Center" 
                                 Margin="10,0,0,0"/>
                    </Grid>
                    
                    <CheckBox x:Name="OptimizeMemoryCheck" Content="启动游戏前进行内存优化" 
                            Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="14" 
                            Margin="0,10,0,0" IsEnabled="False"/>
                    
                    <!-- 内存使用情况 -->
                    <Border Background="{DynamicResource TertiaryBackgroundBrush}" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="已使用内存" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
                                <TextBlock Grid.Column="1" x:Name="UsedMemoryText" 
                                         Text="0 GB / 0 GB" Foreground="{DynamicResource PrimaryForegroundBrush}" 
                                         FontSize="12" HorizontalAlignment="Right"/>
                            </Grid>
                            
                            <ProgressBar x:Name="MemoryProgressBar" 
                                       Value="30" Minimum="0" Maximum="100" 
                                       Height="8" Margin="0,8,0,0"
                                       Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="{DynamicResource AccentBrush}"
                                       BorderThickness="0"/>
                            
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TotalMemoryText" 
                                         Text="0 GB" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
                                <TextBlock Grid.Column="1" x:Name="AllocatedMemoryText" 
                                         Text="0 GB" Foreground="{DynamicResource AccentBrush}" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- 离线皮肤卡片 -->
            <Border Style="{StaticResource CardContainer}" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock Text="离线皮肤" FontSize="18" FontWeight="Bold" 
                             Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                    
                    <StackPanel Margin="0,5">
                        <RadioButton x:Name="RandomSkinRadio" Content="随机" 
                                   Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="14" 
                                   IsChecked="True" Margin="0,5" GroupName="SkinGroup"/>
                        <RadioButton x:Name="SteveSkinRadio" Content="Steve" 
                                   Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="14" 
                                   Margin="0,5" GroupName="SkinGroup"/>
                        <RadioButton x:Name="AlexSkinRadio" Content="Alex" 
                                   Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="14" 
                                   Margin="0,5" GroupName="SkinGroup"/>
                        <RadioButton x:Name="CustomSkinRadio" Content="正版皮肤" 
                                   Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="14" 
                                   Margin="0,5" GroupName="SkinGroup"/>
                    </StackPanel>
                    
                    <Grid x:Name="CustomSkinPanel" Visibility="Collapsed" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="CustomSkinPathTextBox" 
                                   Style="{StaticResource ModernTextBox}"
                                   IsReadOnly="True" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" x:Name="BrowseSkinButton" 
                                  Content="浏览..." HorizontalAlignment="Right" 
                                  Click="BrowseSkinButton_Click"
                                  Style="{StaticResource ModernButton}"/>
                    </Grid>
                    
                    <Border x:Name="SkinPreviewBorder" Background="{DynamicResource TertiaryBackgroundBrush}" 
                          CornerRadius="8" Height="150" Margin="0,15,0,0"
                          BorderBrush="{DynamicResource SecondaryBackgroundBrush}" BorderThickness="1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path Data="{StaticResource IconPark_User}" Fill="{DynamicResource AccentBrush}" 
                                  Width="56" Height="56" HorizontalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5"/>
                            <TextBlock Text="皮肤预览" Foreground="{DynamicResource SecondaryForegroundBrush}" 
                                     FontSize="14" HorizontalAlignment="Center"
                                     Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- 高级选项卡片 -->
            <Border Style="{StaticResource CardContainer}" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock Text="高级选项" FontSize="18" FontWeight="Bold" 
                             Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Java 虚拟机参数" VerticalAlignment="Top" 
                                 Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,5,10,0"/>
                        <TextBox Grid.Column="1" x:Name="JavaArgsTextBox" 
                               Style="{StaticResource ModernTextBox}"
                               Height="100" TextWrapping="Wrap" 
                               AcceptsReturn="True" 
                               VerticalScrollBarVisibility="Auto"
                               Text="-XX:+UseG1GC -XX:+UseAdaptiveSizePolicy -XX:-OmitStackTraceInFastThrow -Djdk.lang.Process.allowAmbiguousCommands=true -Dfml.ignoreInvalidMinecraftCertificates=true -Dfml.ignorePatchDiscrepancies=true -Dlog4j2.formatMsgNoLookups=true"/>
                    </Grid>
                    
                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="游戏参数" VerticalAlignment="Center" 
                                 Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBox Grid.Column="1" x:Name="GameArgsTextBox" 
                               Style="{StaticResource ModernTextBox}"/>
                    </Grid>
                    
                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="启动前执行命令" VerticalAlignment="Center" 
                                 Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBox Grid.Column="1" x:Name="PreLaunchCommandTextBox" 
                               Style="{StaticResource ModernTextBox}"/>
                    </Grid>
                    
                    <CheckBox x:Name="DisableJavaWrapperCheck" Content="禁用 Java Launch Wrapper" 
                            Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="14" Margin="150,10,0,0"/>
                    
                    <CheckBox x:Name="UseDedicatedGPUCheck" Content="使用高性能显卡" 
                            Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="14" Margin="150,5,0,0"
                            IsChecked="True"/>
                    
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="下载模式" VerticalAlignment="Center" 
                                 Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <ComboBox Grid.Column="1" x:Name="DownloadModeComboBox" 
                                Style="{StaticResource ModernComboBox}" 
                                SelectedIndex="0">
                            <ComboBoxItem Content="单线程（稳定）"/>
                            <ComboBoxItem Content="多线程（快速）"/>
                        </ComboBox>
                    </Grid>
                    
                    <Border x:Name="DownloadModeInfoBorder" Background="{DynamicResource TertiaryBackgroundBrush}" 
                          CornerRadius="8" Padding="12" Margin="150,10,0,0"
                          BorderBrush="{DynamicResource SecondaryBackgroundBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="DownloadModeInfoText" 
                                     TextWrapping="Wrap" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="12">
                                <Run FontWeight="Bold">单线程模式：</Run>每次下载 3 个文件，稳定性高，适合网络不稳定的环境<LineBreak/>
                                <Run FontWeight="Bold">多线程模式：</Run>同时下载 10 个文件，速度更快，适合高速网络环境
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- 保存按钮 -->
            <Button x:Name="SaveSettingsButton" Content="保存设置" 
                  Click="SaveSettingsButton_Click" 
                  Style="{StaticResource ModernButton}" 
                  HorizontalAlignment="Center" 
                  Padding="30,12" FontSize="16" 
                  Margin="0,30,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>

<Page x:Class="MinecraftLauncher.SaveDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="存档详情" Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="20,0,20,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Content="← 返回" Click="BackButton_Click"
                    Style="{StaticResource ModernButton}" Padding="15,8"/>
            
            <TextBlock Grid.Column="1" Text="{Binding SaveName}" FontSize="24" FontWeight="Bold" 
                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                       HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            
            <Button Grid.Column="2" Content="开始游戏" Click="PlayButton_Click"
                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource PrimaryBackgroundBrush}"
                    BorderThickness="0" Padding="20,10" FontWeight="Bold"/>
        </Grid>
        
        <!-- 存档基本信息 -->
        <Border Grid.Row="1" Style="{StaticResource CardContainer}" Margin="20,0,20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="游戏版本" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding GameVersion}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForegroundBrush}" HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="游戏模式" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding DisplayGameMode}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForegroundBrush}" HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="难度" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding DisplayDifficulty}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForegroundBrush}" HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="总游戏时长" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding DisplayPlayTime}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 存档详细信息 -->
        <Border Grid.Row="2" Style="{StaticResource CardContainer}" Margin="20,0,20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Text="世界类型" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                    <TextBlock Text="{Binding DisplayWorldType}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="0,3,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,10,10">
                    <TextBlock Text="作弊" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                    <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,3,0,0"
                               Foreground="{DynamicResource PrimaryForegroundBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}">
                                <Binding Path="HasCheats" Converter="{StaticResource BoolToTextConverter}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,0,10" Orientation="Horizontal">
                    <StackPanel>
                        <TextBlock Text="种子" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{Binding Seed}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                    </StackPanel>
                    <Button Content="复制" Click="CopySeedButton_Click" Margin="10,15,0,0"
                            Style="{StaticResource ModernButton}" Padding="8,3" FontSize="11"
                            Visibility="{Binding Seed, Converter={StaticResource StringToVisibilityConverter}}"/>
                </StackPanel>
                
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0" Orientation="Horizontal">
                    <TextBlock Text="最后游玩：" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                    <TextBlock Text="{Binding DisplayLastPlayed}" FontSize="12" 
                               Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="5,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 模组配置 -->
        <Border Grid.Row="3" Style="{StaticResource CardContainer}" Margin="20,0,20,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="模组配置" FontSize="18" FontWeight="Bold" 
                               Foreground="{DynamicResource AccentBrush}"/>
                    
                    <TextBlock Grid.Column="1" x:Name="ModCountText" 
                               Text="{Binding EnabledMods.Count, StringFormat='已启用 {0} 个模组'}"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="15,0,0,0"/>
                    
                    <Button Grid.Column="2" Content="刷新" Click="RefreshButton_Click"
                            Style="{StaticResource ModernButton}" Padding="10,5" Margin="0,0,10,0"/>
                    
                    <Button Grid.Column="3" Content="模组文件夹" Click="OpenModsFolderButton_Click"
                            Style="{StaticResource ModernButton}" Padding="10,5" Margin="0,0,10,0"/>
                    
                    <Button Grid.Column="4" Content="存档文件夹" Click="OpenFolderButton_Click"
                            Style="{StaticResource ModernButton}" Padding="10,5"/>
                </Grid>
                
                <ListBox Grid.Row="1" x:Name="ModsListBox" 
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         BorderBrush="{DynamicResource TertiaryBackgroundBrush}" BorderThickness="1"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" CornerRadius="3" Padding="6,2" Margin="0,0,10,0"
                                        Background="{Binding IsEnabled, Converter={StaticResource BoolToColorConverter}}">
                                    <TextBlock Text="{Binding IsEnabled, Converter={StaticResource BoolToStatusConverter}}"
                                               FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                           Foreground="{DynamicResource PrimaryForegroundBrush}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                
                                <Button Grid.Column="2" Content="{Binding IsEnabled, Converter={StaticResource BoolToToggleConverter}}"
                                        Click="ToggleModButton_Click" Tag="{Binding}"
                                        Style="{StaticResource ModernButton}" Padding="10,3" FontSize="11"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <TextBlock x:Name="NoModsText" Grid.Row="1" 
                           Text="暂无模组配置，将使用全局模组设置"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
        
        <!-- 底部操作栏 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,20">
            <Button Content="打开存档文件夹" Click="OpenFolderButton_Click"
                    Style="{StaticResource ModernButton}" Padding="20,10" Margin="0,0,15,0"/>
            <Button Content="开始游戏" Click="PlayButton_Click"
                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource PrimaryBackgroundBrush}"
                    BorderThickness="0" Padding="30,10" FontWeight="Bold" FontSize="14"/>
        </StackPanel>
    </Grid>
</Page>

<UserControl x:Class="MinecraftLauncher.ModpackPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="900"
             Background="Transparent">
    
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Name="TitleText" Text="本地整合包" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                <Button x:Name="ViewModeButton" Content="浏览在线"
                        Click="ViewModeButton_Click"
                        Background="{DynamicResource TertiaryBackgroundBrush}" 
                        Foreground="{DynamicResource PrimaryForegroundBrush}"
                        BorderBrush="{DynamicResource SecondaryBackgroundBrush}" 
                        BorderThickness="1"
                        Padding="12,6" FontSize="12" Margin="15,0,0,0"/>
            </StackPanel>
            <TextBlock Text="导入和管理游戏整合包，直接启动游玩" FontSize="13" 
                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
        </StackPanel>
        
        <!-- 操作按钮区域 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ImportModpackButton" Content="导入整合包" 
                        Click="ImportModpackButton_Click"
                        Background="{DynamicResource AccentBrush}" Foreground="#1a1a1a"
                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                        Padding="15,8" FontSize="13" FontWeight="SemiBold">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,6,0"/>
                                <TextBlock Text="导入整合包" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
                
                <Button x:Name="RefreshButton" Content="刷新列表" 
                        Click="RefreshButton_Click"
                        Background="{DynamicResource TertiaryBackgroundBrush}" Foreground="{DynamicResource PrimaryForegroundBrush}"
                        BorderBrush="{DynamicResource SecondaryBackgroundBrush}" BorderThickness="1"
                        Padding="15,8" Margin="12,0,0,0" FontSize="13"/>
                
                <TextBlock x:Name="ModpackCountText" Text="共 0 个整合包" 
                           Foreground="{DynamicResource SecondaryForegroundBrush}" 
                           VerticalAlignment="Center" Margin="20,0,0,0" FontSize="13"/>
            </StackPanel>
            
            <!-- 状态文本 -->
            <TextBlock x:Name="StatusText" Text="" 
                       Foreground="{DynamicResource SecondaryForegroundBrush}" 
                       Margin="0,8,0,0" FontSize="12"/>
            
            <!-- 下载进度条 -->
            <Border x:Name="DownloadProgressPanel" Visibility="Collapsed" 
                    Background="{DynamicResource TertiaryBackgroundBrush}" 
                    CornerRadius="5" Padding="12" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock x:Name="DownloadFileNameText" Text="正在下载..." 
                               Foreground="{DynamicResource PrimaryForegroundBrush}" 
                               FontSize="12" Margin="0,0,0,8"/>
                    <ProgressBar x:Name="DownloadProgressBar" Height="8" 
                                 Background="{DynamicResource SecondaryBackgroundBrush}" 
                                 Foreground="{DynamicResource AccentBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
        
        <!-- 整合包列表 -->
        <ListBox x:Name="ModpacksListBox" Grid.Row="2" 
                 Background="{DynamicResource SecondaryBackgroundBrush}" 
                 Foreground="{DynamicResource PrimaryForegroundBrush}"
                 BorderBrush="{DynamicResource TertiaryBackgroundBrush}" 
                 BorderThickness="1"
                 SelectionChanged="ModpacksListBox_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource TertiaryBackgroundBrush}" CornerRadius="8" Padding="15" Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 整合包图标 -->
                            <Border Grid.Column="0" Width="80" Height="80" CornerRadius="6" 
                                    Background="{DynamicResource SecondaryBackgroundBrush}" Margin="0,0,15,0">
                                <Image Source="{Binding IconPath}" Stretch="UniformToFill"
                                       Width="80" Height="80"/>
                            </Border>
                            
                            <!-- 整合包信息 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" 
                                           Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="游戏版本：" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                    <TextBlock Text="{Binding GameVersion}" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text="  |  作者：" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding Author}" FontSize="11" Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" FontSize="11" 
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" 
                                           TextWrapping="Wrap" MaxHeight="36" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="下载次数：" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="10"/>
                                    <TextBlock Text="{Binding Downloads}" FontSize="10" Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text=" | 类型：" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="10" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding ModLoader}" FontSize="10" Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- 操作按钮 -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <Button Content="启动游戏" 
                                        Click="LaunchModpackButton_Click"
                                        Tag="{Binding}"
                                        Background="{DynamicResource AccentBrush}" Foreground="#1a1a1a"
                                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                        Padding="20,8" FontSize="13" FontWeight="SemiBold"
                                        Margin="0,0,0,8"/>
                                <Button Content="删除" 
                                        Click="DeleteModpackButton_Click"
                                        Tag="{Binding}"
                                        Background="Transparent" Foreground="#e74c3c"
                                        BorderBrush="#e74c3c" BorderThickness="1"
                                        Padding="20,8" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <!-- 空状态提示 -->
        <Border x:Name="EmptyStatePanel" Grid.Row="2" 
                Background="{DynamicResource SecondaryBackgroundBrush}" 
                CornerRadius="8" Padding="40"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="暂无整合包" FontSize="18" FontWeight="Bold" 
                           Foreground="{DynamicResource PrimaryForegroundBrush}" 
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="点击上方「导入整合包」或「浏览在线」获取整合包" FontSize="13" 
                           Foreground="{DynamicResource SecondaryForegroundBrush}" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
<Page x:Class="MinecraftLauncher.AccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource PrimaryBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="账号管理" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,20"/>

        <!-- 账号列表 -->
        <Border Grid.Row="1" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="8" Padding="10">
            <ListBox x:Name="AccountListBox" 
                     Background="Transparent" 
                     BorderThickness="0"
                     SelectionChanged="AccountListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Name}" FontSize="16" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="{Binding TypeText}" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center">
            <Button Content="添加账号" Width="120" Height="35" Margin="5" 
                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource PrimaryBackgroundBrush}" BorderThickness="0"
                    Click="AddAccountButton_Click"/>
            <Button Content="微软登录" Width="120" Height="35" Margin="5" 
                    Background="#0078D4" Foreground="White" BorderThickness="0"
                    Click="MicrosoftLoginButton_Click"/>
            <Button Content="删除账号" Width="120" Height="35" Margin="5" 
                    Background="#e94560" Foreground="White" BorderThickness="0"
                    Click="DeleteAccountButton_Click"/>
        </StackPanel>
    </Grid>
</Page>

<Window x:Class="MinecraftLauncher.OfflineLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="离线登录" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#16213e" CornerRadius="8" BorderBrush="#FFD700" BorderThickness="2">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#1a1a2e" CornerRadius="6,6,0,0" 
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Height="40" VerticalAlignment="Top">
                <TextBlock Text="离线登录" FontSize="18" FontWeight="Bold" Foreground="#FFD700" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <!-- 内容区域 -->
            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                <TextBlock Text="玩家名称" Foreground="#FFD700" Margin="0,0,0,5"/>
                <TextBox x:Name="NameTextBox" Height="30" Margin="0,0,0,15" 
                         Background="#1a1a2e" Foreground="White" BorderBrush="#FFD700" BorderThickness="1"/>
                
                <TextBlock Text="UUID (可选，留空自动生成)" Foreground="#FFD700" Margin="0,0,0,5"/>
                <TextBox x:Name="UuidTextBox" Height="30" Margin="0,0,0,15" 
                         Background="#1a1a2e" Foreground="White" BorderBrush="#FFD700" BorderThickness="1"/>
                
                <TextBlock Text="提示：玩家名称长度为 3-16 个字符，只能使用字母和数字" 
                           Foreground="#888" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="取消" Width="80" Height="30" Margin="5" 
                        Background="#888" Foreground="White" BorderThickness="0"
                        Click="CancelButton_Click"/>
                <Button Content="确定" Width="80" Height="30" Margin="5" 
                        Background="#FFD700" Foreground="#1a1a2e" BorderThickness="0"
                        Click="OkButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

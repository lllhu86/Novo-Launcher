<Window x:Class="MinecraftLauncher.MicrosoftLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="微软登录" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#16213e" CornerRadius="8" BorderBrush="#0078D4" BorderThickness="2">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#1a1a2e" CornerRadius="6,6,0,0" 
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Height="40" VerticalAlignment="Top">
                <TextBlock Text="微软账号登录" FontSize="18" FontWeight="Bold" Foreground="#0078D4" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <!-- 内容区域 -->
            <StackPanel Grid.Row="1" Margin="0,20,0,0" VerticalAlignment="Center">
                <TextBlock Text="请在浏览器中完成登录" Foreground="White" FontSize="16" 
                           HorizontalAlignment="Center" Margin="0,0,0,20" TextWrapping="Wrap"/>
                
                <TextBlock Text="用户代码：" Foreground="#0078D4" FontSize="14" Margin="0,0,0,10"/>
                <TextBox x:Name="UserCodeTextBox" Height="40" FontSize="24" 
                         Background="#1a1a2e" Foreground="#0078D4" BorderBrush="#0078D4" BorderThickness="2"
                         HorizontalAlignment="Center" Width="200" TextAlignment="Center"
                         IsReadOnly="True"/>
                
                <TextBlock Text="已自动复制到剪贴板并打开浏览器" Foreground="#888" FontSize="12" 
                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
                
                <TextBlock Text="请在浏览器中访问：https://www.microsoft.com/link" Foreground="#888" FontSize="12" 
                           HorizontalAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap"/>
                
                <TextBlock x:Name="StatusTextBlock" Text="等待浏览器登录..." Foreground="#FFD700" FontSize="14" 
                           HorizontalAlignment="Center" Margin="0,20,0,0"/>
                
                <ProgressBar x:Name="LoginProgressBar" Height="5" Margin="0,10,0,0" 
                             IsIndeterminate="True" Maximum="900"/>
            </StackPanel>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="取消" Width="100" Height="35" Margin="5" 
                        Background="#888" Foreground="White" BorderThickness="0"
                        Click="CancelButton_Click"/>
                <Button x:Name="RetryButton" Content="重试" Width="100" Height="35" Margin="5" 
                        Background="#0078D4" Foreground="White" BorderThickness="0"
                        Visibility="Collapsed" Click="RetryButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
